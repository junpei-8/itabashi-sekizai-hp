---
import { buttonVariants } from '@/components/ui/button';
import { Phone } from 'lucide-react';
---

<a href="tel:0229-25-8445" aria-label="有限会社板橋石材へ電話をかける" class={buttonVariants({ size: 'icon-lg', className: 'fixed bottom-4 left-4 z-50 shadow-lg shadow-primary/25 md:hidden' })}><Phone className="size-5" aria-hidden="true" /></a>

<script is:inline>
  const callButton = document.querySelector('a[aria-label="有限会社板橋石材へ電話をかける"]');

  const toggleCallButton = () => {
    if (!(callButton instanceof HTMLElement)) return;

    callButton.classList.toggle('hidden', window.scrollY < 160);
  };

  toggleCallButton();
  window.addEventListener('scroll', toggleCallButton, { passive: true });
</script>

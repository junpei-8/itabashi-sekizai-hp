---
import { Phone } from 'lucide-react';
---

<a href="tel:0229-25-8445" aria-label="有限会社板橋石材へ電話をかける" data-mobile-call-button class="pointer-events-none fixed bottom-4 left-4 z-50 inline-flex translate-y-2 items-center gap-2 rounded-full border border-primary/20 bg-primary px-4 py-3 text-sm font-bold tracking-wide text-primary-foreground opacity-0 shadow-lg shadow-foreground/18 transition-[opacity,transform] duration-200 md:hidden">
  <Phone className="size-4" aria-hidden="true" />
  <span>0229-25-8445</span>
</a>

<script is:inline>
  const callButton = document.querySelector('[data-mobile-call-button]');
  let lastScrollY = window.scrollY;

  const toggleCallButton = () => {
    if (!(callButton instanceof HTMLElement)) return;

    const currentScrollY = window.scrollY;
    const isScrollingUp = currentScrollY < lastScrollY;
    const shouldShow = currentScrollY >= 160 && isScrollingUp;

    callButton.classList.toggle('pointer-events-none', !shouldShow);
    callButton.classList.toggle('translate-y-2', !shouldShow);
    callButton.classList.toggle('opacity-0', !shouldShow);

    lastScrollY = currentScrollY;
  };

  toggleCallButton();
  window.addEventListener('scroll', toggleCallButton, { passive: true });
</script>

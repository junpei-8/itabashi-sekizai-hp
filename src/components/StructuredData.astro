---
import { siteConfig } from '@/config/site';

const site = Astro.site ?? new URL(siteConfig.url);
const url = new URL('/', site).toString();
const image = new URL(siteConfig.ogImage, site).toString();
const gbpUrl = import.meta.env.PUBLIC_GBP_URL;
const sameAs = gbpUrl ? [gbpUrl] : undefined;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': siteConfig.business.type,
  '@id': `${url}#business`,
  name: siteConfig.name,
  image,
  url,
  telephone: siteConfig.business.telephone,
  faxNumber: siteConfig.business.faxNumber,
  address: {
    '@type': 'PostalAddress',
    postalCode: siteConfig.business.postalCode,
    addressRegion: siteConfig.business.addressRegion,
    addressLocality: siteConfig.business.addressLocality,
    streetAddress: siteConfig.business.streetAddress,
    addressCountry: 'JP',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: siteConfig.geo.latitude,
    longitude: siteConfig.geo.longitude,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: siteConfig.business.openingDays,
      opens: siteConfig.business.opens,
      closes: siteConfig.business.closes,
    },
  ],
  areaServed: siteConfig.business.areaServed.map((name) => ({
    '@type': name.startsWith('宮城県') ? 'AdministrativeArea' : 'Place',
    name,
  })),
  priceRange: siteConfig.business.priceRange,
  ...(sameAs ? { sameAs } : {}),
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

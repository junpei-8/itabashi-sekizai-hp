---
import { buttonVariants } from '@/components/ui/button';
import { Card, CardContent } from '@/components/ui/card';
import { MessageCircle, Phone } from 'lucide-react';
---

<section class="container mx-auto px-4 py-16">
  <Card className="rounded-[2rem] bg-foreground p-0 py-0 text-background">
    <CardContent className="grid gap-8 p-8 md:grid-cols-[1fr_auto] md:items-center md:p-12">
      <div>
        <p class="text-base font-bold tracking-[0.28em] text-muted">お問い合わせ</p>
        <h2 class="mt-3 font-serif-jp text-2xl font-semibold tracking-[0.12em] md:text-4xl">お墓のことで迷ったら、まずはご相談ください</h2>
        <p class="mt-4 text-base leading-8 text-background/82">新設・建て替え・追加彫刻・清掃・改葬まで、現地の状況に合わせてご案内します。</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
        <a href="tel:0229-25-8445" class={buttonVariants({ size: 'lg', className: 'gap-2 text-center' })}><Phone className="size-5" aria-hidden="true" />0229-25-8445</a>
        <a href="#contact" class={buttonVariants({ size: 'lg', variant: 'heroOutline', className: 'gap-2 border-background/45 bg-background/8 text-center hover:bg-background/14' })}><MessageCircle className="size-5" aria-hidden="true" />お問い合わせ案内</a>
      </div>
    </CardContent>
  </Card>
</section>
